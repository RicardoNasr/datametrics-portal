{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "app.html", "use": "@vercel/static" },
    { "src": "dashboard.html", "use": "@vercel/static" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/login", "dest": "/api/login.js" },
    { "src": "/api/shopify/install", "dest": "/api/shopify/install.js" },
    { "src": "/api/shopify/callback", "dest": "/api/shopify/callback.js" },
    { "src": "/api/shopify/gdpr", "dest": "/api/shopify/gdpr.js" },
    { "src": "/api/shopify/refresh-token", "dest": "/api/shopify/refresh-token.js" },
    { "src": "/api/shopify/stats", "dest": "/api/shopify/stats.js" },
    { "src": "/api/shopify/token-exchange", "dest": "/api/shopify/token-exchange.js" },
    { "src": "/api/shopify/token-exchange-v2", "dest": "/api/shopify/token-exchange-v2.js" },
    { "src": "/api/shopify/dashboard-link", "dest": "/api/shopify/dashboard-link.js" },
    { "src": "/app", "dest": "/app.html" },
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/privacy", "dest": "/public/privacy.html" },
    { "src": "/install-success", "dest": "/public/install-success.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/app",
      "headers": [
        { "key": "Content-Security-Policy", "value": "frame-ancestors https://*.myshopify.com https://admin.shopify.com;" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/api/shopify/stats",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    },
    {
      "source": "/api/shopify/dashboard-link",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
